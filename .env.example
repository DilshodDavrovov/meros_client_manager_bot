# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Comma-separated list of allowed Telegram user IDs (e.g. 123456789,987654321)
# If empty, use allowed_users table in SQLite
ALLOWED_USER_IDS=123456789,987654321

# Smartup API
SMARTUP_BASE_URL=https://smartup.merospharm.uz/b/anor/mr/person
SMARTUP_LOGIN=animi@meros
SMARTUP_PASSWORD=your_password
# auth: session (login form + cookies) | basic (Authorization header)
SMARTUP_AUTH_TYPE=session
# URL for session login (used when AUTH_TYPE=session)
SMARTUP_LOGIN_URL=https://smartup.merospharm.uz/login
SMARTUP_HTTP_TIMEOUT_MS=30000
SMARTUP_MAX_RETRIES=3

# SQLite file path (default: ./data/meros_bot.db)
DB_PATH=./data/meros_bot.db

# Group ID for deferral (only 136 - Отсрочка_Платежа)
DEFERRAL_GROUP_IDS=136
